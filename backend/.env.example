# Backend Environment Variables
# Copy this file to .env and fill in the values

# Server Configuration
PORT=3000

# Database Configuration (for local development)
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=daily_quotes_postgres_db

# Database Configuration (for Docker Compose)
# DB_HOST=db
# DB_PORT=5432

# JWT Configuration
JWT_SECRET=your_secure_jwt_secret_key_here_change_this_for_production

# Optional: AI Service Configuration (Ollama)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Optional: Expo Push Notifications
# EXPO_ACCESS_TOKEN=your_expo_access_token_here

# Optional: External API for seeding quotes
# ZENQUOTES_API_URL=https://zenquotes.io/api/quotes